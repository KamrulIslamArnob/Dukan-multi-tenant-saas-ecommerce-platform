{
  "title": "Dukaan API Overview",
  "uid": "dukaan-overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count[1m])) by (http_route)",
          "legendFormat": "{{http_route}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Request Duration p99 (s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_request_duration_seconds_bucket[1m])) by (le, http_route))",
          "legendFormat": "{{http_route}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "HTTP Error Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count{http_response_status_code=~\"5..\"}[1m]))",
          "legendFormat": "5xx errors/s"
        }
      ]
    },
    {
      "id": 4,
      "title": "Application Logs",
      "type": "logs",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "uid": "loki" },
      "targets": [
        {
          "expr": "{service_name=\"dukaan-api\"}"
        }
      ]
    },
    {
      "id": 5,
      "title": "GC Heap Size",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "process_runtime_dotnet_gc_heap_size_bytes",
          "legendFormat": "generation {{generation}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Active HTTP Connections",
      "type": "stat",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "kestrel_active_connections",
          "legendFormat": "active connections"
        }
      ]
    }
  ]
}
