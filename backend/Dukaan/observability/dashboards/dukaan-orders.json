{
  "dashboard": {
    "title": "Dukaan Orders",
    "panels": [
      { "title": "Orders Per Minute", "type": "graph", "targets": [{ "expr": "rate(dukaan_orders_created_total[5m])" }] },
      { "title": "Order Value Distribution", "type": "heatmap", "targets": [{ "expr": "rate(dukaan_order_value_bucket[5m])" }] },
      { "title": "Order Status Breakdown", "type": "piechart", "targets": [{ "expr": "dukaan_orders_by_status" }] }
    ],
    "time": { "from": "now-24h", "to": "now" },
    "refresh": "1m"
  }
}
